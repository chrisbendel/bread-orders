<% content_for :title, "Contact" %>

<div class="stack-lg">
  <div class="stack-sm">
    <h2>Get in touch</h2>
    <p class="text-muted">Have feedback, an idea, or a question? I'd love to hear from you.</p>
  </div>

  <%= form_with url: contact_path, method: :post, class: "stack" do |f| %>
    <div>
      <%= f.label :name, "Name" %>
      <%= f.text_field :name, placeholder: "Your name (optional)" %>
    </div>

    <div>
      <%= f.label :email, "Email" %>
      <%= f.email_field :email, placeholder: "your@email.com (optional, for replies)" %>
    </div>

    <div>
      <%= f.label :message, "Message" %>
      <%= f.text_area :message, rows: 6, placeholder: "What's on your mind?", required: true %>
    </div>

    <%= f.submit "Send", class: "button primary", style: "align-self: flex-start" %>
  <% end %>
</div>

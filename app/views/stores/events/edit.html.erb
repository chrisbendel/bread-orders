<% content_for :title, "#{@event.name} — Edit" %>
<h1>Edit Event</h1>

<%= form_with model: [@event], local: true do |form| %>
  <div>
    <%= form.label :name %><br>
    <%= form.text_field :name, required: true %>
  </div>

  <div>
    <%= form.label :description %><br>
    <%= form.text_area :description %>
  </div>

  <div class="group">

    <div>
      <%= form.label :orders_close_at, "Orders close at" %><br>
      <%= form.date_field :orders_close_at, required: true, min: Date.current %>
    </div>
  </div>

  <div>
    <%= form.label :pickup_at, "Pickup date" %><br>
    <%= form.date_field :pickup_at, required: true, min: Date.current %>
  </div>

  <div>
    <%= form.submit "Save Changes" %>
  </div>
<% end %>

<hr style="border: none; border-top: 1px solid var(--border); margin-block: var(--sp-lg);">

<div class="stack-sm">
  <p class="text-sm font-bold text-danger">Danger Zone</p>
  <% if @event.orders.any? %>
    <p class="text-muted text-sm">This event has <%= pluralize(@event.orders.count, "order") %>. Deleting it will also delete all associated orders.</p>
  <% end %>
  <div class="group">
    <%= button_to "Delete Event", event_path(@event), 
        method: :delete, 
        class: "button danger small",
        data: { turbo_confirm: "Are you sure? This will permanently delete the event and all associated orders." } %>
  </div>
</div>

<p style="margin-top: var(--sp-lg);">
  <%= link_to "← Back to event", event_path(@event) %>
</p>

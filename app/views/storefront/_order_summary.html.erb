<section class="panel stack-sm">
  <% if order&.order_items&.any? %>
    <div class="group justify-between items-baseline">
      <span class="text-sm font-bold"><%= event.orders_closed? ? "Order confirmed" : "Your order" %></span>
      <span class="font-bold"><%= number_to_currency(order.total_price) %></span>
    </div>

    <div class="stack-sm">
      <% order.order_items.includes(:event_product).each do |item| %>
        <div class="group justify-between items-center">
          <span class="text-sm"><%= item.event_product.name %></span>
          <span class="group items-center">
            <span class="text-sm text-muted">×<%= item.quantity %></span>
            <% if event.orders_open? %>
              <%= button_to "✕", storefront_order_item_path(store.slug, item),
                  method: :delete,
                  class: "button-link text-muted text-sm",
                  aria: { label: "Remove #{item.event_product.name}" } %>
            <% end %>
          </span>
        </div>
      <% end %>
    </div>

    <p class="text-sm text-muted" style="border-top: 1px solid var(--border); padding-top: var(--sp-sm);">
      Pickup <%= pickup_datetime(event.pickup_at) %>
    </p>
  <% else %>
    <p class="text-sm text-muted">No items yet.</p>
  <% end %>
</section>
